# ============================================================================
# Azaton Frontend - Environment Variables
# ============================================================================

# API Backend URL
# Для Docker (nginx proxy): /api
# Для локального dev: http://localhost:3000/api
# Для доступа по IP в локальной сети: http://192.168.1.5:3000/api
# Для удаленного сервера Ubuntu: http://109.123.253.238:3000/api
VITE_API_URL=http://109.123.253.238:3000/api

# Для Docker/nginx используй:
# VITE_API_URL=/api

# Socket.io URL (относительный путь для Docker/nginx проксирования)
VITE_SOCKET_URL=
