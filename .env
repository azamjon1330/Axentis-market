# ============================================================================
# Azaton Frontend - Environment Variables
# ============================================================================

# API Backend URL
# Для Docker (nginx proxy): /api
# Для локального dev: http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# For Docker/nginx deployment use:
# VITE_API_URL=/api

# Socket.io URL (относительный путь для Docker/nginx проксирования)
VITE_SOCKET_URL=
